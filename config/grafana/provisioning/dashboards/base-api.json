{
  "uid": "realtime-gateway-v1",
  "title": "realtime-gateway — application dashboard",
  "tags": ["spring-boot", "java", "realtime-gateway"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Requests / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"realtime-gateway\"}[5m])) * 60",
        "legendFormat": "req/min"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "blue", "value": null }
        ]}
      }}
    },

    {
      "id": 2, "type": "stat", "title": "Error rate (5xx)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"realtime-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"realtime-gateway\"}[5m])) * 100",
        "legendFormat": "error %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 5 }
        ]}
      }}
    },

    {
      "id": 3, "type": "stat", "title": "Latencia media HTTP (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_sum{job=\"realtime-gateway\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"realtime-gateway\"}[5m])) * 1000",
        "legendFormat": "avg ms"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 200 },
          { "color": "red", "value": 1000 }
        ]}
      }}
    },

    {
      "id": 4, "type": "stat", "title": "Heap usado (%)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(jvm_memory_used_bytes{job=\"realtime-gateway\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"realtime-gateway\",area=\"heap\"}) * 100",
        "legendFormat": "heap %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 85 }
        ]}
      }}
    },

    {
      "id": 5, "type": "timeseries", "title": "Llamadas a use cases (por segundo)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(usecase_calls_total{job=\"realtime-gateway\",status=\"success\"}[5m])",
          "legendFormat": "{{usecase}} — ok"
        },
        {
          "expr": "rate(usecase_calls_total{job=\"realtime-gateway\",status=\"error\"}[5m])",
          "legendFormat": "{{usecase}} — error"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 6, "type": "timeseries", "title": "Latencia media por use case (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(usecase_execution_seconds_sum{job=\"realtime-gateway\"}[5m]) / rate(usecase_execution_seconds_count{job=\"realtime-gateway\"}[5m]) * 1000",
        "legendFormat": "{{usecase}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 7, "type": "timeseries", "title": "HTTP — requests por segundo por URI",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by(uri, method, status) (rate(http_server_requests_seconds_count{job=\"realtime-gateway\"}[5m]))",
        "legendFormat": "{{method}} {{uri}} {{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },

    {
      "id": 8, "type": "timeseries", "title": "JVM — memoria heap (MB)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"realtime-gateway\",area=\"heap\"}) / 1048576",
          "legendFormat": "heap usado"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"realtime-gateway\",area=\"heap\"}) / 1048576",
          "legendFormat": "heap máximo"
        },
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"realtime-gateway\",area=\"nonheap\"}) / 1048576",
          "legendFormat": "non-heap usado"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "megabytes", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 9, "type": "timeseries", "title": "HikariCP — conexiones al pool de BD",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"realtime-gateway\"}",
          "legendFormat": "activas"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"realtime-gateway\"}",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"realtime-gateway\"}",
          "legendFormat": "en espera"
        },
        {
          "expr": "hikaricp_connections_max{job=\"realtime-gateway\"}",
          "legendFormat": "máximo"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 10, "type": "timeseries", "title": "Circuit breaker — estado",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "targets": [{
        "expr": "resilience4j_circuitbreaker_state{job=\"realtime-gateway\"}",
        "legendFormat": "{{name}} (0=closed 1=open 2=half-open)"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 },
          { "color": "yellow", "value": 2 }
        ]}
      }},
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 11, "type": "timeseries", "title": "CPU — uso del proceso (%)",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "targets": [{
        "expr": "process_cpu_usage{job=\"realtime-gateway\"} * 100",
        "legendFormat": "cpu %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 60 },
          { "color": "red", "value": 85 }
        ]}
      }},
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
